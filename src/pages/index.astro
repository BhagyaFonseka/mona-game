<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
	</head>
	<body>
		<header>
			<h1>Mona Mayhem</h1>
			<p class="subtitle">GitHub Contribution Battle Arena</p>
		</header>

		<main>
			<section class="battle-form">
				<div class="player-inputs">
					<div class="player">
						<label for="player1">Player 1</label>
						<input
							id="player1"
							type="text"
							placeholder="GitHub username"
							autocomplete="off"
							spellcheck="false"
						/>
					</div>

					<div class="vs">VS</div>

					<div class="player">
						<label for="player2">Player 2</label>
						<input
							id="player2"
							type="text"
							placeholder="GitHub username"
							autocomplete="off"
							spellcheck="false"
						/>
					</div>
				</div>

				<button id="battle-btn">⚔ Battle!</button>
			</section>

			<section id="results" class="results" hidden>
				<div class="result-card" id="result-player1"></div>
				<div class="winner-banner" id="winner-banner"></div>
				<div class="result-card" id="result-player2"></div>
			</section>

			<p id="error-msg" class="error-msg" hidden></p>
		</main>

		<script>
			const battleBtn = document.getElementById('battle-btn') as HTMLButtonElement;
			const resultsSection = document.getElementById('results') as HTMLElement;
			const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;
			const winnerBanner = document.getElementById('winner-banner') as HTMLDivElement;
			const resultPlayer1 = document.getElementById('result-player1') as HTMLDivElement;
			const resultPlayer2 = document.getElementById('result-player2') as HTMLDivElement;

			battleBtn.addEventListener('click', async () => {
				const player1 = (document.getElementById('player1') as HTMLInputElement).value.trim();
				const player2 = (document.getElementById('player2') as HTMLInputElement).value.trim();

				if (!player1 || !player2) {
					showError('Please enter both usernames.');
					return;
				}

				hideError();
				resultsSection.hidden = true;
				battleBtn.disabled = true;
				battleBtn.textContent = 'Loading...';

				try {
					const [res1, res2] = await Promise.all([
						fetch(`/api/contributions/${encodeURIComponent(player1)}`),
						fetch(`/api/contributions/${encodeURIComponent(player2)}`),
					]);

					const [data1, data2] = await Promise.all([res1.json(), res2.json()]);

					if (!res1.ok) {
						showError(`Error fetching data for ${player1}: ${data1.error ?? res1.statusText}`);
						return;
					}
					if (!res2.ok) {
						showError(`Error fetching data for ${player2}: ${data2.error ?? res2.statusText}`);
						return;
					}

					renderResults(player1, data1, player2, data2);
				} catch (err) {
					showError('Something went wrong. Please try again.');
				} finally {
					battleBtn.disabled = false;
					battleBtn.textContent = '⚔ Battle!';
				}
			});

			function renderResults(name1: string, data1: unknown, name2: string, data2: unknown) {
				// TODO: Replace with real contribution totals once the API is implemented
				resultPlayer1.innerHTML = `<h2>${name1}</h2><p class="contributions">??? contributions</p>`;
				resultPlayer2.innerHTML = `<h2>${name2}</h2><p class="contributions">??? contributions</p>`;
				winnerBanner.textContent = '🏆 Battle complete!';
				resultsSection.hidden = false;
			}

			function showError(message: string) {
				errorMsg.textContent = message;
				errorMsg.hidden = false;
			}

			function hideError() {
				errorMsg.hidden = true;
			}
		</script>
	</body>
</html>

<style>
